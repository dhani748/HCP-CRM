# ============================================================
# HCP CRM — Monorepo .gitignore
# Backend: Python / FastAPI / SQLAlchemy / Alembic / LangGraph
# Frontend: React / TypeScript / Vite
# ============================================================

# ──────────────────────────────────────────────────────────
# Environment & Secrets
# ──────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.crt
secrets/

# ──────────────────────────────────────────────────────────
# Python
# ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
.eggs/
sdist/
wheels/
*.whl
MANIFEST
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
.venv/
venv/
ENV/
env/
env.bak/
venv.bak/
.virtualenv/

# Testing
.pytest_cache/
.coverage
.coverage.*
coverage.xml
coverage/
htmlcov/
*.log
junit.xml
test-results/

# Mypy / type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.pyre/

# Ruff / Linters
.ruff_cache/

# ──────────────────────────────────────────────────────────
# Alembic
# ──────────────────────────────────────────────────────────
# Keep migration versions but ignore local SQLite test DBs
*.db
*.sqlite
*.sqlite3

# ──────────────────────────────────────────────────────────
# LangGraph / LangChain
# ──────────────────────────────────────────────────────────
.langchain/
langgraph.json.lock

# ──────────────────────────────────────────────────────────
# Node / npm / Frontend
# ──────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.yarn/

# Vite build output
frontend/dist/
frontend/.vite/

# TypeScript
*.tsbuildinfo

# ESLint cache
.eslintcache

# ──────────────────────────────────────────────────────────
# IDEs & Editors
# ──────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ──────────────────────────────────────────────────────────
# Docker
# ──────────────────────────────────────────────────────────
.dockerignore
docker-compose.override.yml

# ──────────────────────────────────────────────────────────
# Logs & OS
# ──────────────────────────────────────────────────────────
*.log
logs/
*.pid
*.seed
*.pid.lock

# ──────────────────────────────────────────────────────────
# Misc
# ──────────────────────────────────────────────────────────
.cache/
tmp/
temp/
